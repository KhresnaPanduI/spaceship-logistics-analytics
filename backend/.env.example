# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# Required: your OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-replace-me

# Optional: which model to call via OpenRouter.
# Check https://openrouter.ai/models?q=sonnet for the current Sonnet model ID.
LLM_MODEL=anthropic/claude-sonnet-4.6

# Optional: OpenRouter base URL (rarely needs changing).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: comma-separated allowed origins for CORS.
# Add your Vercel frontend URL here once deployed.
CORS_ORIGINS=http://localhost:3000

# Optional: safety stock buffer used in the inventory recommendation formula.
SAFETY_STOCK_PCT=0.20
